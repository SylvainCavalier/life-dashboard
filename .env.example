# =============================================================================
# Environment Variables - Copy this file to .env and fill in your values
# =============================================================================

# --- Database (PostgreSQL) ---
PGUSER=postgres
PGPASSWORD=
PGHOST=localhost
# DATABASE_URL=postgres://user:pass@host:5432/dbname  # Production only

# --- Rails ---
RAILS_ENV=development
RAILS_MASTER_KEY=        # Required in production (see config/master.key)
RAILS_MAX_THREADS=10
RAILS_LOG_LEVEL=info     # debug, info, warn, error, fatal

# --- Server ---
PORT=3000
WEB_CONCURRENCY=2        # Number of Puma workers in production

# --- Background Jobs (GoodJob) ---
GOOD_JOB_MAX_THREADS=5

# --- Mailer ---
MAILER_FROM=noreply@example.com

# --- Demo mode (no database required) ---
# SKIP_DB_CHECKS=true
